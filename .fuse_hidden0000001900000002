  <div class="wrap nav">
    <a href="/" class="logo">St<svg class="o" viewBox="0 0 28 28" aria-hidden="true"><rect x="3.5" y="3.5" width="21" height="21" rx="5" fill="none" stroke="currentColor" stroke-width="3.2"/><rect x="5" y="13" width="18" height="3" fill="var(--coral)"/></svg>rey<span class="brick"></span></a>
