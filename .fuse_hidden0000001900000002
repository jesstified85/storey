<main>
  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow reveal">Contact</p>
      <h1 class="reveal">Let’s build<br>something.</h1>
      <p class="lede reveal">Tell us what you're working on — brand, website, app, or all three. We'll get back to you with next steps and a clear estimate. No pitch, no pressure.</p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <form class="form reveal" action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
        <div class="field"><label for="name">Name</label><input id="name" name="name" type="text" required></div>
        <div class="field"><label for="email">Email</label><input id="email" name="email" type="email" required></div>
        <div class="field"><label for="company">Company</label><input id="company" name="company" type="text"></div>
        <div class="field"><label for="type">What do you need?</label>
          <select id="type" name="type">
            <option>Brand</option><option>Website</option><option>App</option>
            <option>Brand + Website</option><option>The whole arc (brand + site + app)</option><option>Not sure yet</option>
          </select>
        </div>
        <div class="field"><label for="budget">Ballpark budget</label>
          <select id="budget" name="budget">
            <option>Under $15k</option><option>$15k–$35k</option><option>$35k–$75k</option><option>$75k+</option><option>Not sure yet</option>
          </select>
        </div>
        <div class="field"><label for="timeline">Ideal timeline</label>
          <select id="timeline" name="timeline">
            <option>ASAP</option><option>1–3 months</option><option>3–6 months</option><option>Just exploring</option>
          </select>
        </div>
        <div class="field full"><label for="msg">Tell us about the project</label><textarea id="msg" name="msg" placeholder="What are you building, and what does success look like?"></textarea></div>
        <div class="field full"><button type="submit" class="btn btn-primary">Send it →</button></div>
      </form>
      <div id="thanks" style="display:none;max-width:720px" class="reveal">
        <h2 class="big">Thanks — that’s in.</h2>
        <p class="prose">We’ll be in touch within two business days. In the meantime, feel free to email us directly at <a href="mailto:hello@madebystorey.com" style="color:var(--coral);font-weight:600">hello@madebystorey.com</a>.</p>
      </div>
      <p class="reveal" style="margin-top:26px;color:var(--ink-soft);font-size:14px">Prefer email? <a href="mailto:hello@madebystorey.com" style="color:var(--coral);font-weight:600">hello@madebystorey.com</a> &nbsp;·&nbsp; This form is a prototype — connect it to your email or a form service before launch.</p>
    </div>
  </section>
</main>

